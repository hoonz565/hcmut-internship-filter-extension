{
  "manifest_version": 3,
  "name": "HCMUT Internship Filter",
  "version": "1.0",
  "description": "Filter companies on the HCMUT Internship Portal by slot availability and location.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://internship.cse.hcmut.edu.vn/*"
  ],
  "icons": {
    "16": "icon/logo.jpg",
    "48": "icon/logo.jpg",
    "128": "icon/logo.jpg"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://internship.cse.hcmut.edu.vn/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}
